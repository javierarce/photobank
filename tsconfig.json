{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "src/app",
    "src/db",
    "src/worker",
    "src/proxy.ts",
    "src/lib/auth.ts",
    "src/lib/queue.ts",
    "src/lib/redis.ts",
    "src/lib/s3.ts",
    "src/lib/tags.ts",
    "src/__tests__/api",
    "src/__tests__/auth.test.ts",
    "src/__tests__/process-image.test.ts",
    "src/__tests__/use-upload.test.tsx"
  ]
}
