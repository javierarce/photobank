# dependencies
/node_modules

# this repo uses npm (package-lock.json); a stray pnpm lockfile makes
# tauri-action pick pnpm and breaks releases — keep it out (see #22)
pnpm-lock.yaml

# testing
/coverage

# vite
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# typescript
*.tsbuildinfo
