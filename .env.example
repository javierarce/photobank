DATABASE_URL=postgresql://user@localhost:5432/photobank

S3_REGION=eu-west-3
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
# Optional: set for S3-compatible services (MinIO, R2, ...)
# S3_ENDPOINT=

# Optional: public CDN in front of the bucket; when unset, images are served
# through /api/images with presigned URLs
# NEXT_PUBLIC_CDN_URL=

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# HTTP Basic auth for the whole app. Leave AUTH_PASSWORD empty to disable
# (fine for local dev; set it before exposing the app anywhere).
AUTH_USERNAME=admin
AUTH_PASSWORD=
